# ============================================================
# Hybrid Hut — Stripe Terminal Configuration
# ============================================================
# Copy this file to .env and fill in your values.

# Your Stripe Secret Key (starts with sk_test_ or sk_live_)
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_SECRET_KEY_HERE

# Your WisePOS E Reader ID (starts with tmr_)
# Find this in Stripe Dashboard → Terminal → Readers
STRIPE_TERMINAL_READER_ID=tmr_YOUR_READER_ID_HERE

# Frontend URL (for CORS — use * in development)
FRONTEND_URL=*

# Server port
PORT=3001

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hybrid_hut
DB_USER=hybridhut
DB_PASSWORD=YOUR_DB_PASSWORD_HERE

# Admin PIN for kiosk admin panel
ADMIN_PIN=2200
